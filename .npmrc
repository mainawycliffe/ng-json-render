strict-peer-dependencies=false
auto-install-peers=true

# npm auth token is read from the NPM_TOKEN environment variable (never commit the token itself).
# Local:  export NPM_TOKEN=npm_xxx   (use an Automation token to skip the 2FA OTP prompt)
# CI:     set NPM_TOKEN as a repo/organization secret
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
